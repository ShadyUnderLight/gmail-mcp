{
  "name": "gmail-mcp",
  "version": "1.0.0",
  "description": "MCP server for Gmail - let AI agents read, send, and manage your emails",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gmail-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
