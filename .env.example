# Google Cloud OAuth2 credentials
# Create a project at https://console.cloud.google.com/apis/credentials
# Enable the Gmail API, create an OAuth 2.0 Client ID (Desktop app type)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
# Optional: override the default OAuth redirect port (default: 3000)
OAUTH_PORT=3000
